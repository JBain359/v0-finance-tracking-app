# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Descope Authentication
NEXT_PUBLIC_DESCOPE_PROJECT_ID=your-descope-project-id

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Other Environment Variables
NODE_ENV=development

# ===========================================
# IMPORTANT: RLS Configuration
# ===========================================
# After setting up RLS, you need to configure Supabase to accept Descope JWTs:
#
# 1. Go to Supabase Dashboard → Authentication → Providers → JWT
# 2. Enable JWT Provider
# 3. Add your Descope Public Key (PEM format)
#    - Get this from: Descope Dashboard → Project Settings → JWT → Public Key
# 4. Optionally set JWKS URL: https://api.descope.com/v2/keys/YOUR_PROJECT_ID
#
# This allows Supabase RLS policies to validate and read the Descope JWT token.
# The user ID from the 'sub' claim will be used to filter all database queries.
